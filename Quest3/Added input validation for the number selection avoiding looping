/* The purpose of this program is to allow the user to encode messages, decode
messages, and decode their encoded messages by guessing the shift value */
#include <iostream>
#include <string>
using namespace std;

// CaesarCipher class definition
class CaesarCipher {
private:
    int shiftValue;
protected:
    string encode(const string &message) {
        string encoded = "";
        // Loop through each character in the message and apply the shift
        for (char c : message) {
            int ascii = static_cast<int>(c);
            if (isupper(c)) {
                encoded += (ascii - 65 + shiftValue) % 26 + 65;
            } else if (islower(c)) {
                encoded += (ascii - 97 + shiftValue) % 26 + 97;
            } else {
                encoded += c;
            }
        }
        return encoded;
    }

public:
    // Constructor to initialize shift value
    CaesarCipher() {
        shiftValue = 0;
    }
    void setShiftValue(int value) {
        shiftValue = value % 26;
    }
    // Method to decode the message by reversing the shift
    string decode(const string &message) {
        int original = shiftValue;
        shiftValue = 26 - shiftValue;
        string decoded = encode(message);
        shiftValue = original;
        return decoded;
    }
    // Method to get the encoded message
    string getEncoded(const string &message) {
        return encode(message);
    }
};

class Rot13Cipher : public CaesarCipher {
public:
    // Constructor to set the shift value to 13 for ROT13 cipher
    Rot13Cipher() {
        setShiftValue(13);
    }
};

// Function to get a valid choice from the user ('y' or 'n')
char getChoice() {
    char choice;
    cin >> choice;
    choice = tolower(choice);
    while (choice != 'y' && choice != 'n') {
        cout << "Invalid input. Please enter 'y' or 'n': ";
        cin >> choice;
        choice = tolower(choice);
    }
    return choice;
}

// Function to decode the encoded message by allowing the user to guess the shift value
void decodeEncoded(const string &message, const string &encoded) {
    cout << "Do you want to decode the recent captured message? ('y' or 'n'): ";
    char choice = getChoice();
    if (choice == 'y') {
        while (true) {
            int guess;
            cout << "Enter your guess for the shift value (1-25) to decode the message: ";
            while (!(cin >> guess) || guess < 1 || guess > 25) {
                cin.clear();
                cin.ignore(10000, '\n');
                cout << "Invalid input. Please enter a number between 1 and 25: ";
            }
            CaesarCipher *cipher;
            string decoded;
            // Check if the guess is 13 to use ROT13 cipher, otherwise use Caesar cipher with the guessed shift value
            if (guess == 13) {
                cipher = new Rot13Cipher();
                cout << "Decoding message using Rot13 Cipher (shift value 13): " << endl;
            } else {
                cipher = new CaesarCipher();
                cipher->setShiftValue(guess);
                cout << "Decoding message using Caesar Cipher (shift value "
                << guess << "): " << endl;
            }
            decoded = cipher->decode(encoded);
            cout << "Encoded Message: " << encoded << endl;
            cout << "Decoded message: " << decoded << endl;
            delete cipher;
            cout << "Do you think your guess is correct? ('y' or 'n'): ";
            choice = getChoice();
            // If the user thinks their guess is correct, check if the decoded message matches the original message
            if (choice == 'y') {
                if (message == decoded) {
                    cout << "Congratulations! You guessed the correct shift value!" << endl;
                    break;
                } else {
                    cout << "Incorrect guess. Try again." << endl;
                    continue; // If the guess is incorrect, allow the user to try again
                }
            } else {
                cout << "Try again." << endl;
                continue;
            }
        }
    }
}

int main() {
    string message;
    char choice;
    bool encodeExit, decodeExit;
    cout << "~~~~~~~~~~ Welcome to the Cipher Program! ~~~~~~~~~~" << endl;
    // Main loop to allow the user to encode and decode messages until choose neither
    while (true) {
        cout << "Do you want to encode a new message? ('y' or 'n'): ";
        choice = getChoice();
        if (choice == 'y') {
            encodeExit = false;
            cin.ignore();
            cout << "Enter the message to be encoded: ";
            getline(cin, message);
            int shift;
            cout << "Enter a shift value (1-25) to encode the message accordingly: ";
            while (!(cin >> shift) || shift < 1 || shift > 25) {
                cin.clear();
                cin.ignore(10000, '\n');
                cout << "Invalid input. Please enter a number between 1 and 25: ";
            }
            CaesarCipher *cipher;
            string encoded;
            // Check if the shift value is 13 to use ROT13 cipher, otherwise use Caesar cipher with the specified shift value
            if (shift == 13) {
                cipher = new Rot13Cipher();
                encoded = cipher->getEncoded(message);
                cout << "Encoded message using Rot13 Cipher (shift value 13): " << encoded << endl;
            } else {
                cipher = new CaesarCipher();
                cipher->setShiftValue(shift);
                encoded = cipher->getEncoded(message);
                cout << "Encoded message using Caesar Cipher (shift value "
                << shift << "): " << encoded << endl;
            }
            delete cipher; // Clean up dynamically allocated memory
            decodeEncoded(message, encoded); // Call the function to allow the user to decode the recently captured message
        } else {
            encodeExit = true; // If the user chooses not to encode a message trigger one exit condition
        }
        // Ask the user if they want to decode a message
        cout << "Do you want to decode a message? ('y' or 'n'): ";
        choice = getChoice();
        if (choice == 'y') {
            decodeExit = false;
            cin.ignore();
            cout << "Enter the message to be decoded: ";
            getline(cin, message);
            int shift;
            cout << "Enter a shift value (1-25) to decode the message accordingly: ";
            while (!(cin >> shift) || shift < 1 || shift > 25) {
                cin.clear();
                cin.ignore(10000, '\n');
                cout << "Invalid input. Please enter a number between 1 and 25: ";
            }
            CaesarCipher *cipher;
            string decoded;
            // Check if the shift value is 13 to use ROT13 cipher, otherwise use Caesar cipher with the specified shift value
            if (shift == 13) {
                cipher = new Rot13Cipher();
                decoded = cipher->decode(message);
                cout << "Decoded message using Rot13 Cipher (shift value 13): " << decoded << endl;
            } else {
                cipher = new CaesarCipher();
                cipher->setShiftValue(shift);
                decoded = cipher->decode(message);
                cout << "Decoded message using Caesar Cipher (shift value "
                << shift << "): " << decoded << endl;
            }
            delete cipher; // Clean up dynamically allocated memory
        } else {
            decodeExit = true; // If the user chooses not to decode a message trigger one exit condition
        }
        // If both exit conditions are triggered, exit the program
        if (encodeExit && decodeExit) {
            cout << "Exiting the program." << endl;
            break;
        }
    }
    return 0;
}
